<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.kinit-refresh-status</string>

    <key>ProgramArguments</key>
    <array>
        <string>@/bin/kinit-refresh-status</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/kinit-refresh-status.stdout</string>

    <key>StandardErrorPath</key>
    <string>/tmp/kinit-refresh-status.stderr</string>
</dict>
</plist>
