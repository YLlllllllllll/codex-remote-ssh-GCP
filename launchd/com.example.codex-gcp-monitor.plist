<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.codex-gcp-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>@HOME@/bin/codex-gcp-monitor</string>
        <string>sample</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/codex-gcp-monitor.stdout</string>
    <key>StandardErrorPath</key>
    <string>/tmp/codex-gcp-monitor.stderr</string>
</dict>
</plist>
