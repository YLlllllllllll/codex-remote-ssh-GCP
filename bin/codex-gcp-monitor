#!/usr/bin/env bash
set -Eeuo pipefail

LOCAL_USER="$(id -un)"
LOCAL_HOME="${LOCAL_HOME:-$(dscl . -read "/Users/${LOCAL_USER}" NFSHomeDirectory 2>/dev/null | awk '{ print $2; exit }')}"
LOCAL_HOME="${LOCAL_HOME:-$HOME}"
export HOME="$LOCAL_HOME"

CONFIG_FILE="${CODEX_GCP_REFRESH_CONFIG:-$LOCAL_HOME/.config/codex-gcp-refresh/config.env}"
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

GCP_HOST="${GCP_HOST:-203.0.113.10}"
GCP_USER="${GCP_USER:-gcp-user}"
GCP_PORT="${GCP_PORT:-443}"
GCP_KEY="${GCP_KEY:-$LOCAL_HOME/.ssh/google_compute_engine}"
GCP_EXPECTED_IP="${GCP_EXPECTED_IP:-203.0.113.10}"
GCP_TRAFFIC_IFACE="${GCP_TRAFFIC_IFACE:-ens4}"
TRAFFIC_24H_WARN_BYTES="${TRAFFIC_24H_WARN_BYTES:-1073741824}"
TRAFFIC_24H_CRITICAL_BYTES="${TRAFFIC_24H_CRITICAL_BYTES:-3221225472}"
REMOTE_HOST="${REMOTE_HOST:-${SSH_PROBE_TARGET:-remote-workspace}}"

LOCAL_HTTP_HOST="${LOCAL_HTTP_HOST:-127.0.0.1}"
LOCAL_HTTP_PORT="${LOCAL_HTTP_PORT:-7890}"
LOCAL_SOCKS_PORT="${LOCAL_SOCKS_PORT:-1080}"
REMOTE_HTTP_HOST="${REMOTE_HTTP_HOST:-127.0.0.1}"
REMOTE_HTTP_PORT="${REMOTE_HTTP_PORT:-10800}"
IP_CHECK_URL="${MONITOR_IP_CHECK_URL:-http://api.ipify.org}"
CHATGPT_CODEX_URL="${CHATGPT_CODEX_URL:-https://chatgpt.com/backend-api/codex/responses}"
MONITOR_CONNECT_TIMEOUT="${MONITOR_CONNECT_TIMEOUT:-3}"
MONITOR_MAX_TIME="${MONITOR_MAX_TIME:-8}"
MONITOR_MAX_BYTES="${MONITOR_MAX_BYTES:-10485760}"

STATE_DIR="${STATE_DIR:-$LOCAL_HOME/.codex-gcp-tunnel}"
LOG_FILE="${MONITOR_LOG_FILE:-$STATE_DIR/monitor.jsonl}"
LATEST_FILE="${MONITOR_LATEST_FILE:-$STATE_DIR/monitor-latest.env}"
SESSIONS_FILE="${MONITOR_SESSIONS_FILE:-$STATE_DIR/active-sessions.txt}"
LOCAL_HTTP_URL="http://${LOCAL_HTTP_HOST}:${LOCAL_HTTP_PORT}"
REMOTE_HTTP_URL="http://${REMOTE_HTTP_HOST}:${REMOTE_HTTP_PORT}"

json_escape() {
  sed 's/\\/\\\\/g; s/"/\\"/g; s/	/\\t/g' | tr '\n' ' '
}

json_value() {
  printf '%s' "$1" | json_escape
}

route_field() {
  local target="$1"
  local field="$2"
  route -n get "$target" 2>/dev/null | awk -v f="$field" '$1 == f ":" { print $2; exit }'
}

listener_pids() {
  local port="$1"
  { lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null || true; } | paste -sd, -
}

listener_count() {
  local port="$1"
  local pids
  pids="$(listener_pids "$port")"
  if [[ -z "$pids" ]]; then
    printf '0\n'
  else
    awk -F, '{ print NF }' <<<"$pids"
  fi
}

curl_local_http_ip() {
  curl -sS --connect-timeout "$MONITOR_CONNECT_TIMEOUT" --max-time "$MONITOR_MAX_TIME" \
    -x "$LOCAL_HTTP_URL" "$IP_CHECK_URL" 2>/dev/null || true
}

tcp_check() {
  nc -vz -G "$MONITOR_CONNECT_TIMEOUT" "$GCP_HOST" "$GCP_PORT" >/dev/null 2>&1 && printf ok || printf fail
}

gcp_counter_probe() {
  ssh \
    -i "$GCP_KEY" \
    -o IdentitiesOnly=yes \
    -p "$GCP_PORT" \
    -o BatchMode=yes \
    -o ConnectTimeout="$MONITOR_CONNECT_TIMEOUT" \
    -o ConnectionAttempts=1 \
    "${GCP_USER}@${GCP_HOST}" \
    "awk -v iface='${GCP_TRAFFIC_IFACE}:' '\$1 == iface { print \$2, \$10; found=1 } END { exit found ? 0 : 1 }' /proc/net/dev" \
    2>/dev/null || true
}

json_number_field() {
  local key="$1"
  awk -v key="$key" '
    function value(line, key, start, rest, out) {
      start = index(line, "\"" key "\":")
      if (!start) {
        return ""
      }
      rest = substr(line, start + length(key) + 3)
      out = rest
      sub(/[,}].*/, "", out)
      gsub(/^"|"$/, "", out)
      return out
    }
    {
      print value($0, key)
    }
  '
}

traffic_delta_since() {
  local since_epoch="$1"
  local rx_now="$2"
  local tx_now="$3"

  if [[ ! "$rx_now" =~ ^[0-9]+$ || ! "$tx_now" =~ ^[0-9]+$ || ! -f "$LOG_FILE" ]]; then
    printf '0\n'
    return
  fi

  awk -v since="$since_epoch" -v rx_now="$rx_now" -v tx_now="$tx_now" '
    function value(line, key, start, rest, out) {
      start = index(line, "\"" key "\":")
      if (!start) {
        return ""
      }
      rest = substr(line, start + length(key) + 3)
      out = rest
      sub(/[,}].*/, "", out)
      gsub(/^"|"$/, "", out)
      return out
    }
    {
      epoch = value($0, "epoch") + 0
      rx = value($0, "gcp_rx_bytes")
      tx = value($0, "gcp_tx_bytes")
      counter_ok = value($0, "gcp_counter_ok")
      usable = (counter_ok == "true" || (counter_ok == "" && (rx + 0 > 0 || tx + 0 > 0)))
      if (epoch >= since && usable && rx ~ /^[0-9]+$/ && tx ~ /^[0-9]+$/) {
        if (first_epoch == 0 || epoch < first_epoch) {
          first_epoch = epoch
          first_rx = rx + 0
          first_tx = tx + 0
        }
      }
    }
    END {
      if (first_epoch == 0) {
        print 0
        exit
      }
      delta = (rx_now - first_rx) + (tx_now - first_tx)
      if (delta < 0) {
        delta = 0
      }
      print delta
    }
  ' "$LOG_FILE"
}

traffic_rate_bps() {
  local epoch_now="$1"
  local rx_now="$2"
  local tx_now="$3"

  if [[ ! "$rx_now" =~ ^[0-9]+$ || ! "$tx_now" =~ ^[0-9]+$ || ! -f "$LOG_FILE" ]]; then
    printf '0\n'
    return
  fi

  awk -v epoch_now="$epoch_now" -v rx_now="$rx_now" -v tx_now="$tx_now" '
    function value(line, key, start, rest, out) {
      start = index(line, "\"" key "\":")
      if (!start) {
        return ""
      }
      rest = substr(line, start + length(key) + 3)
      out = rest
      sub(/[,}].*/, "", out)
      gsub(/^"|"$/, "", out)
      return out
    }
    {
      epoch = value($0, "epoch") + 0
      rx = value($0, "gcp_rx_bytes")
      tx = value($0, "gcp_tx_bytes")
      counter_ok = value($0, "gcp_counter_ok")
      usable = (counter_ok == "true" || (counter_ok == "" && (rx + 0 > 0 || tx + 0 > 0)))
      if (epoch > 0 && epoch < epoch_now && usable && rx ~ /^[0-9]+$/ && tx ~ /^[0-9]+$/) {
        last_epoch = epoch
        last_rx = rx + 0
        last_tx = tx + 0
      }
    }
    END {
      if (last_epoch == 0 || epoch_now <= last_epoch) {
        print 0
        exit
      }
      delta = (rx_now - last_rx) + (tx_now - last_tx)
      if (delta < 0) {
        delta = 0
      }
      print int(delta / (epoch_now - last_epoch))
    }
  ' "$LOG_FILE"
}

human_bytes() {
  awk -v bytes="${1:-0}" 'BEGIN {
    split("B KiB MiB GiB TiB", unit, " ")
    value = bytes + 0
    idx = 1
    while (value >= 1024 && idx < 5) {
      value = value / 1024
      idx++
    }
    if (idx == 1) {
      printf "%d %s", value, unit[idx]
    } else {
      printf "%.1f %s", value, unit[idx]
    }
  }'
}

traffic_status_for() {
  local bytes_24h="${1:-0}"
  if [[ ! "$bytes_24h" =~ ^[0-9]+$ ]]; then
    printf 'unknown\n'
  elif [[ "$bytes_24h" -ge "$TRAFFIC_24H_CRITICAL_BYTES" ]]; then
    printf 'critical\n'
  elif [[ "$bytes_24h" -ge "$TRAFFIC_24H_WARN_BYTES" ]]; then
    printf 'warning\n'
  else
    printf 'ok\n'
  fi
}

json_optional_number() {
  local value="${1:-}"
  if [[ "$value" =~ ^[0-9]+$ ]]; then
    printf '%s' "$value"
  else
    printf 'null'
  fi
}

remote_probe() {
  ssh \
    -o BatchMode=yes \
    -o ConnectTimeout="$MONITOR_CONNECT_TIMEOUT" \
    -o ConnectionAttempts=1 \
    -o ServerAliveInterval=5 \
    -o ServerAliveCountMax=1 \
    "$REMOTE_HOST" \
    "REMOTE_HTTP_PORT='$REMOTE_HTTP_PORT' REMOTE_HTTP_URL='$REMOTE_HTTP_URL' IP_CHECK_URL='$IP_CHECK_URL' CHATGPT_CODEX_URL='$CHATGPT_CODEX_URL' MONITOR_CONNECT_TIMEOUT='$MONITOR_CONNECT_TIMEOUT' MONITOR_MAX_TIME='$MONITOR_MAX_TIME' bash -s" <<'REMOTE' || return $?
set -u
listen_count="$(ss -ltn 2>/dev/null | awk -v port="$REMOTE_HTTP_PORT" '$4 ~ ":" port "$" { count++ } END { print count + 0 }')"
socket_count="$(ss -tnp 2>/dev/null | awk -v port="$REMOTE_HTTP_PORT" '$4 ~ ":" port "$" || $5 ~ ":" port "$" { count++ } END { print count + 0 }')"
proxy_ip="$(curl -sS --connect-timeout "$MONITOR_CONNECT_TIMEOUT" --max-time "$MONITOR_MAX_TIME" -x "$REMOTE_HTTP_URL" "$IP_CHECK_URL" 2>/dev/null || true)"
chatgpt_code="$(curl -sS -o /dev/null -w '%{http_code}' --connect-timeout "$MONITOR_CONNECT_TIMEOUT" --max-time "$MONITOR_MAX_TIME" -x "$REMOTE_HTTP_URL" "$CHATGPT_CODEX_URL" 2>/dev/null || true)"
app_server_count="$(ps -eo args= 2>/dev/null | grep -E 'codex app-server proxy|app-server --listen unix://' | grep -v grep | wc -l | tr -d ' ')"
notty_count="$(ps -eo args= 2>/dev/null | grep -E 'sshd: .*@notty' | grep -v grep | wc -l | tr -d ' ')"
session_lines="$(ps -eo pid=,ppid=,etimes=,etime=,pcpu=,pmem=,args= 2>/dev/null | awk '
  /\/bin\/codex exec/ && $0 !~ /awk / {
    args = ""
    for (i = 7; i <= NF; i++) {
      args = args (i == 7 ? "" : " ") $i
    }
    if (length(args) > 180) {
      args = substr(args, 1, 177) "..."
    }
    printf "pid=%s ppid=%s age=%ss etime=%s cpu=%s mem=%s cmd=%s\n", $1, $2, $3, $4, $5, $6, args
  }
')"
codex_exec_count="$(printf '%s\n' "$session_lines" | awk 'NF { count++ } END { print count + 0 }')"
printf 'REMOTE_LISTEN=%s\n' "$listen_count"
printf 'REMOTE_10800_SOCKET_COUNT=%s\n' "$socket_count"
printf 'REMOTE_PROXY_IP=%s\n' "$proxy_ip"
printf 'CHATGPT_CODE=%s\n' "$chatgpt_code"
printf 'REMOTE_APP_SERVER_COUNT=%s\n' "$app_server_count"
printf 'REMOTE_NOTTY_COUNT=%s\n' "$notty_count"
printf 'REMOTE_CODEX_EXEC_COUNT=%s\n' "$codex_exec_count"
printf 'CODEX_SESSION_DETAIL_BEGIN\n'
if [ -n "$session_lines" ]; then
  printf '%s\n' "$session_lines"
else
  printf 'no codex exec workers\n'
fi
printf 'CODEX_SESSION_DETAIL_END\n'
REMOTE
}

rotate_if_needed() {
  mkdir -p "$STATE_DIR"
  if [[ -f "$LOG_FILE" ]]; then
    local size
    size="$(wc -c < "$LOG_FILE" 2>/dev/null || echo 0)"
    if [[ "$size" -gt "$MONITOR_MAX_BYTES" ]]; then
      tail -n 5000 "$LOG_FILE" > "${LOG_FILE}.tmp" 2>/dev/null || true
      mv "${LOG_FILE}.tmp" "$LOG_FILE"
    fi
  fi
}

sample() {
  rotate_if_needed

  local ts epoch default_iface default_gateway gcp_iface gcp_gateway
  local socks_count http_count socks_pids http_pids local_http_ip gcp_tcp
  local remote_rc remote_output remote_error remote_err_file remote_listen remote_proxy_ip chatgpt_code remote_app_count remote_notty_count
  local remote_10800_socket_count remote_codex_exec_count remote_session_detail
  local status cause status_file_status status_file_message
  local gcp_counter_output gcp_rx_bytes gcp_tx_bytes gcp_counter_ok traffic_today_bytes traffic_24h_bytes traffic_rate_bytes_per_sec traffic_status
  local traffic_today_human traffic_24h_human traffic_rate_human today_start_epoch yesterday_epoch

  epoch="$(date +%s)"
  ts="$(date '+%Y-%m-%dT%H:%M:%S%z')"
  today_start_epoch="$(date -j -v0H -v0M -v0S '+%s' 2>/dev/null || date '+%s')"
  yesterday_epoch="$((epoch - 86400))"
  default_iface="$(route_field default interface || true)"
  default_gateway="$(route_field default gateway || true)"
  gcp_iface="$(route_field "$GCP_HOST" interface || true)"
  gcp_gateway="$(route_field "$GCP_HOST" gateway || true)"
  socks_count="$(listener_count "$LOCAL_SOCKS_PORT")"
  http_count="$(listener_count "$LOCAL_HTTP_PORT")"
  socks_pids="$(listener_pids "$LOCAL_SOCKS_PORT")"
  http_pids="$(listener_pids "$LOCAL_HTTP_PORT")"
  local_http_ip="$(curl_local_http_ip)"
  gcp_tcp="$(tcp_check)"
  gcp_counter_output="$(gcp_counter_probe)"
  gcp_rx_bytes="$(awk '{print $1; exit}' <<<"$gcp_counter_output")"
  gcp_tx_bytes="$(awk '{print $2; exit}' <<<"$gcp_counter_output")"
  if [[ ! "$gcp_rx_bytes" =~ ^[0-9]+$ || ! "$gcp_tx_bytes" =~ ^[0-9]+$ ]]; then
    gcp_rx_bytes=""
    gcp_tx_bytes=""
    gcp_counter_ok="false"
  else
    gcp_counter_ok="true"
  fi
  if [[ "$gcp_counter_ok" == "true" ]]; then
    traffic_today_bytes="$(traffic_delta_since "$today_start_epoch" "${gcp_rx_bytes:-}" "${gcp_tx_bytes:-}")"
    traffic_24h_bytes="$(traffic_delta_since "$yesterday_epoch" "${gcp_rx_bytes:-}" "${gcp_tx_bytes:-}")"
    traffic_rate_bytes_per_sec="$(traffic_rate_bps "$epoch" "${gcp_rx_bytes:-}" "${gcp_tx_bytes:-}")"
    traffic_today_human="$(human_bytes "$traffic_today_bytes")"
    traffic_24h_human="$(human_bytes "$traffic_24h_bytes")"
    traffic_rate_human="$(human_bytes "$traffic_rate_bytes_per_sec")/s"
    traffic_status="$(traffic_status_for "$traffic_24h_bytes")"
  else
    traffic_today_bytes=0
    traffic_24h_bytes=0
    traffic_rate_bytes_per_sec=0
    traffic_today_human="采样失败"
    traffic_24h_human="采样失败"
    traffic_rate_human="采样失败"
    traffic_status="unknown"
  fi
  status_file_status="$(awk -F= '$1=="STATUS" {print $2; exit}' /tmp/kinit-refresh.status 2>/dev/null || true)"
  status_file_message="$(awk -F= '$1=="MESSAGE" {print $2; exit}' /tmp/kinit-refresh.status 2>/dev/null || true)"

  remote_rc=0
  remote_err_file="$STATE_DIR/remote-probe.$$.err"
  remote_output="$(remote_probe 2>"$remote_err_file")" || remote_rc=$?
  remote_error="$(tr '\n' ' ' < "$remote_err_file" 2>/dev/null | cut -c 1-500 || true)"
  rm -f "$remote_err_file" 2>/dev/null || true
  remote_listen="$(awk -F= '$1=="REMOTE_LISTEN" {print $2; exit}' <<<"$remote_output")"
  remote_10800_socket_count="$(awk -F= '$1=="REMOTE_10800_SOCKET_COUNT" {print $2; exit}' <<<"$remote_output")"
  remote_proxy_ip="$(awk -F= '$1=="REMOTE_PROXY_IP" {print $2; exit}' <<<"$remote_output")"
  chatgpt_code="$(awk -F= '$1=="CHATGPT_CODE" {print $2; exit}' <<<"$remote_output")"
  remote_app_count="$(awk -F= '$1=="REMOTE_APP_SERVER_COUNT" {print $2; exit}' <<<"$remote_output")"
  remote_notty_count="$(awk -F= '$1=="REMOTE_NOTTY_COUNT" {print $2; exit}' <<<"$remote_output")"
  remote_codex_exec_count="$(awk -F= '$1=="REMOTE_CODEX_EXEC_COUNT" {print $2; exit}' <<<"$remote_output")"
  remote_session_detail="$(awk '
    /^CODEX_SESSION_DETAIL_BEGIN$/ { capture=1; next }
    /^CODEX_SESSION_DETAIL_END$/ { capture=0; next }
    capture { print }
  ' <<<"$remote_output")"
  remote_10800_socket_count="${remote_10800_socket_count:-0}"
  remote_codex_exec_count="${remote_codex_exec_count:-0}"

  {
    printf 'UPDATED=%s\n' "$ts"
    printf 'REMOTE_HOST=%s\n' "$REMOTE_HOST"
    printf 'REMOTE_CODEX_EXEC_COUNT=%s\n' "$remote_codex_exec_count"
    printf 'REMOTE_10800_SOCKET_COUNT=%s\n' "$remote_10800_socket_count"
    printf 'REMOTE_APP_SERVER_COUNT=%s\n' "${remote_app_count:-0}"
    printf 'REMOTE_NOTTY_COUNT=%s\n' "${remote_notty_count:-0}"
    printf '\n'
    printf '%s\n' "${remote_session_detail:-no codex exec workers}"
  } > "$SESSIONS_FILE"

  status="ok"
  cause="ok"
  if [[ "$gcp_tcp" != "ok" ]]; then
    status="fail"; cause="gcp_tcp_fail"
  elif [[ "$socks_count" == "0" ]]; then
    status="fail"; cause="local_1080_missing"
  elif [[ "$http_count" == "0" ]]; then
    status="fail"; cause="local_7890_missing"
  elif [[ "$local_http_ip" != "$GCP_EXPECTED_IP" ]]; then
    status="fail"; cause="local_7890_bad_egress"
  elif [[ "$remote_rc" -ne 0 ]]; then
    status="fail"; cause="remote_ssh_fail_${remote_rc}"
  elif [[ "${remote_listen:-0}" == "0" ]]; then
    status="fail"; cause="remote_10800_missing"
  elif [[ "$remote_proxy_ip" != "$GCP_EXPECTED_IP" ]]; then
    status="fail"; cause="remote_10800_bad_egress"
  elif [[ ! "$chatgpt_code" =~ ^(2|3|4)[0-9][0-9]$ ]]; then
    status="fail"; cause="chatgpt_unreachable_${chatgpt_code:-empty}"
  fi

  cat > "$LATEST_FILE" <<EOF
UPDATED=$ts
STATUS=$status
CAUSE=$cause
GCP_TCP=$gcp_tcp
LOCAL_1080_COUNT=$socks_count
LOCAL_7890_COUNT=$http_count
LOCAL_7890_IP=$local_http_ip
REMOTE_SSH_RC=$remote_rc
REMOTE_SSH_ERROR=$remote_error
REMOTE_10800_COUNT=${remote_listen:-}
REMOTE_10800_SOCKET_COUNT=$remote_10800_socket_count
REMOTE_10800_IP=$remote_proxy_ip
CHATGPT_CODE=$chatgpt_code
REMOTE_CODEX_EXEC_COUNT=$remote_codex_exec_count
REMOTE_APP_SERVER_COUNT=${remote_app_count:-0}
REMOTE_NOTTY_COUNT=${remote_notty_count:-0}
SESSIONS_DETAIL_FILE=$SESSIONS_FILE
DEFAULT_IFACE=$default_iface
DEFAULT_GATEWAY=$default_gateway
GCP_IFACE=$gcp_iface
GCP_GATEWAY=$gcp_gateway
KINIT_STATUS=$status_file_status
KINIT_MESSAGE=$status_file_message
GCP_COUNTER_IFACE=$GCP_TRAFFIC_IFACE
GCP_COUNTER_OK=$gcp_counter_ok
GCP_RX_BYTES=$gcp_rx_bytes
GCP_TX_BYTES=$gcp_tx_bytes
TRAFFIC_TODAY_BYTES=$traffic_today_bytes
TRAFFIC_TODAY_HUMAN=$traffic_today_human
TRAFFIC_24H_BYTES=$traffic_24h_bytes
TRAFFIC_24H_HUMAN=$traffic_24h_human
TRAFFIC_RATE_BYTES_PER_SEC=$traffic_rate_bytes_per_sec
TRAFFIC_RATE_HUMAN=$traffic_rate_human
TRAFFIC_STATUS=$traffic_status
EOF

  printf '{'
  printf '"ts":"%s",' "$(json_value "$ts")"
  printf '"epoch":%s,' "$epoch"
  printf '"status":"%s",' "$(json_value "$status")"
  printf '"cause":"%s",' "$(json_value "$cause")"
  printf '"gcp_tcp":"%s",' "$(json_value "$gcp_tcp")"
  printf '"default_iface":"%s",' "$(json_value "$default_iface")"
  printf '"default_gateway":"%s",' "$(json_value "$default_gateway")"
  printf '"gcp_iface":"%s",' "$(json_value "$gcp_iface")"
  printf '"gcp_gateway":"%s",' "$(json_value "$gcp_gateway")"
  printf '"gcp_counter_iface":"%s",' "$(json_value "$GCP_TRAFFIC_IFACE")"
  printf '"gcp_counter_ok":%s,' "$gcp_counter_ok"
  printf '"gcp_rx_bytes":%s,' "$(json_optional_number "$gcp_rx_bytes")"
  printf '"gcp_tx_bytes":%s,' "$(json_optional_number "$gcp_tx_bytes")"
  printf '"traffic_today_bytes":%s,' "${traffic_today_bytes:-0}"
  printf '"traffic_24h_bytes":%s,' "${traffic_24h_bytes:-0}"
  printf '"traffic_rate_bytes_per_sec":%s,' "${traffic_rate_bytes_per_sec:-0}"
  printf '"traffic_status":"%s",' "$(json_value "$traffic_status")"
  printf '"local_1080_count":%s,' "${socks_count:-0}"
  printf '"local_1080_pids":"%s",' "$(json_value "$socks_pids")"
  printf '"local_7890_count":%s,' "${http_count:-0}"
  printf '"local_7890_pids":"%s",' "$(json_value "$http_pids")"
  printf '"local_7890_ip":"%s",' "$(json_value "$local_http_ip")"
  printf '"remote_ssh_rc":%s,' "$remote_rc"
  printf '"remote_ssh_error":"%s",' "$(json_value "$remote_error")"
  printf '"remote_10800_count":%s,' "${remote_listen:-0}"
  printf '"remote_10800_socket_count":%s,' "${remote_10800_socket_count:-0}"
  printf '"remote_10800_ip":"%s",' "$(json_value "$remote_proxy_ip")"
  printf '"chatgpt_code":"%s",' "$(json_value "$chatgpt_code")"
  printf '"remote_codex_exec_count":%s,' "${remote_codex_exec_count:-0}"
  printf '"remote_app_server_count":%s,' "${remote_app_count:-0}"
  printf '"remote_notty_count":%s,' "${remote_notty_count:-0}"
  printf '"kinit_status":"%s",' "$(json_value "$status_file_status")"
  printf '"kinit_message":"%s"' "$(json_value "$status_file_message")"
  printf '}\n'
}

monitor_self_test() {
  local tmpdir rate delta
  tmpdir="$(mktemp -d)"
  LOG_FILE="$tmpdir/monitor.jsonl"
  trap 'rm -rf "$tmpdir"' RETURN

  cat > "$LOG_FILE" <<'EOF'
{"epoch":100,"gcp_counter_ok":true,"gcp_rx_bytes":1000,"gcp_tx_bytes":1000}
{"epoch":160,"gcp_rx_bytes":0,"gcp_tx_bytes":0}
{"epoch":180,"gcp_counter_ok":false,"gcp_rx_bytes":null,"gcp_tx_bytes":null}
EOF

  delta="$(traffic_delta_since 0 2200 2800)"
  rate="$(traffic_rate_bps 220 2200 2800)"

  if [[ "$delta" != "3000" ]]; then
    printf 'traffic delta self-test failed: got %s, want 3000\n' "$delta" >&2
    return 1
  fi
  if [[ "$rate" != "25" ]]; then
    printf 'traffic rate self-test failed: got %s, want 25\n' "$rate" >&2
    return 1
  fi

  printf 'codex-gcp-monitor self-test: ok\n'
}

case "${1:-sample}" in
  sample)
    sample >> "$LOG_FILE"
    ;;
  status)
    if [[ -f "$LATEST_FILE" ]]; then
      cat "$LATEST_FILE"
    else
      echo "no monitor sample yet: $LATEST_FILE" >&2
      exit 1
    fi
    ;;
  tail)
    tail -n "${2:-80}" "$LOG_FILE"
    ;;
  path)
    printf '%s\n' "$LOG_FILE"
    ;;
  self-test)
    monitor_self_test
    ;;
  *)
    echo "Usage: codex-gcp-monitor [sample|status|tail [n]|path|self-test]" >&2
    exit 2
    ;;
esac
