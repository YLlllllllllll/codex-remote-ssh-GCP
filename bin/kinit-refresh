#!/bin/bash
# kinit-refresh — refresh Kerberos ticket
#
# 用法:
#   kinit-refresh           # 刷新 ticket
#   kinit-refresh --dry-run smart-repair  # 预览智能修复会执行的动作
#   kinit-refresh status    # 查看当前 ticket 状态
#   kinit-refresh log       # 查看最近的自动刷新日志
#   kinit-refresh save-password  # 保存 kinit 密码到 macOS Keychain
#
# 此脚本同时被 ~/Library/LaunchAgents/com.example.kinit-refresh.plist
# 调用,因此手动执行和定时执行行为完全一致。

LOCAL_USER="$(id -un)"
LOCAL_HOME="$(dscl . -read "/Users/${LOCAL_USER}" NFSHomeDirectory 2>/dev/null | awk '{ print $2; exit }')"
LOCAL_HOME="${LOCAL_HOME:-$HOME}"
export HOME="$LOCAL_HOME"

export PATH="$LOCAL_HOME/bin:$LOCAL_HOME/.local/bin:/Applications/Codex.app/Contents/Resources:/opt/homebrew/bin:/opt/homebrew/sbin:/opt/homebrew/share/google-cloud-sdk/bin:/usr/bin:/bin:/usr/sbin:/sbin"

CONFIG_FILE="${KINIT_REFRESH_CONFIG:-$LOCAL_HOME/.config/codex-gcp-refresh/config.env}"
if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
fi

PRINCIPAL="${PRINCIPAL:-user.name@EXAMPLE.REALM}"
LOG_FILE="/tmp/kinit-refresh.log"
STATUS_FILE="/tmp/kinit-refresh.status"
LOCK_DIR="/tmp/kinit-refresh.lock"
KINIT_TIMEOUT_SECONDS=45
COMMAND_TIMEOUT_SECONDS=20
CODEX_TIMEOUT_SECONDS=240
KILL_GRACE_SECONDS=3
MAX_ATTEMPTS=2
RETRY_DELAY_SECONDS=15
LOCK_STALE_SECONDS=600
KINIT_KEYCHAIN_SERVICE="${KINIT_KEYCHAIN_SERVICE:-example-kinit-refresh}"
KINIT_KEYCHAIN_ACCOUNT="${KINIT_KEYCHAIN_ACCOUNT:-$PRINCIPAL}"
KINIT_LIFETIME="${KINIT_LIFETIME:-24h}"
KINIT_RENEWABLE_LIFE="${KINIT_RENEWABLE_LIFE:-7d}"
JUMP_PROXY_SERVICE="${JUMP_PROXY_SERVICE:-host/jump-proxy.example.invalid@EXAMPLE.REALM}"
SSH_PROBE_TARGET="${SSH_PROBE_TARGET:-remote-workspace.example.invalid}"
JUMP_PROXY_HOST="${JUMP_PROXY_HOST:-}"
if [ -z "$JUMP_PROXY_HOST" ] && [[ "$JUMP_PROXY_SERVICE" == host/*@* ]]; then
    JUMP_PROXY_HOST="${JUMP_PROXY_SERVICE#host/}"
    JUMP_PROXY_HOST="${JUMP_PROXY_HOST%@*}"
fi
CODEX_REFRESH_SCRIPT="${CODEX_REFRESH_SCRIPT:-$LOCAL_HOME/bin/codex-gcp-remote}"
CODEX_MONITOR_SCRIPT="${CODEX_MONITOR_SCRIPT:-$LOCAL_HOME/bin/codex-gcp-monitor}"
CURSOR_RESET_SCRIPT="${CURSOR_RESET_SCRIPT:-$LOCAL_HOME/bin/cursor-remote-reset}"
STATE_DIR="${STATE_DIR:-$LOCAL_HOME/.codex-gcp-tunnel}"
GCP_ENABLED_FILE="${GCP_ENABLED_FILE:-$STATE_DIR/gcp.enabled}"
MONITOR_LATEST_FILE="${MONITOR_LATEST_FILE:-$STATE_DIR/monitor-latest.env}"
SMART_REPAIR_STALE_SOCKET_THRESHOLD="${SMART_REPAIR_STALE_SOCKET_THRESHOLD:-20}"
SMART_REPAIR_CHECK_VERSION="${SMART_REPAIR_CHECK_VERSION:-1}"
DRY_RUN="${KINIT_REFRESH_DRY_RUN:-0}"

if [ "${1:-}" = "--dry-run" ]; then
    DRY_RUN=1
    shift
fi

log() {
    local ts
    ts=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[${ts}] $*" >> "$LOG_FILE"
    [ -t 1 ] && echo "[${ts}] $*"
}

write_status() {
    local status=$1
    local ssh_status=$2
    local proxy_status=$3
    local codex_status=$4
    local exp=$5
    local message=$6
    local tmp_file="${STATUS_FILE}.$$"

    {
        echo "STATUS=${status}"
        echo "SSH=${ssh_status}"
        echo "PROXY=${proxy_status}"
        echo "CODEX=${codex_status}"
        echo "EXP=${exp}"
        echo "MESSAGE=${message}"
        echo "UPDATED=$(date '+%Y-%m-%d %H:%M:%S')"
        echo "UPDATED_EPOCH=$(date '+%s')"
    } > "$tmp_file"
    mv "$tmp_file" "$STATUS_FILE"
}

cleanup() {
    rm -f "${LOCK_DIR}/pid" 2>/dev/null || true
    rmdir "$LOCK_DIR" 2>/dev/null || true
}

kill_process_tree() {
    local signal=$1
    local pid=$2
    local child

    for child in $(pgrep -P "$pid" 2>/dev/null || true); do
        kill_process_tree "$signal" "$child"
    done

    kill "-${signal}" "$pid" 2>/dev/null || true
}

wait_until_exited() {
    local pid=$1
    local timeout_seconds=$2
    local elapsed=0

    while kill -0 "$pid" 2>/dev/null; do
        if [ "$elapsed" -ge "$timeout_seconds" ]; then
            return 1
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    return 0
}

terminate_process_tree() {
    local pid=$1

    kill_process_tree TERM "$pid"
    if ! wait_until_exited "$pid" "$KILL_GRACE_SECONDS"; then
        kill_process_tree KILL "$pid"
    fi
    wait "$pid" 2>/dev/null || true
}

ssh_control_path_for() {
    local host=$1
    local path

    path=$(/usr/bin/ssh -G "$host" 2>/dev/null | awk '/^controlpath / { print $2; exit }')
    case "$path" in
        "~/"*) path="${HOME}/${path#~/}" ;;
    esac
    printf '%s\n' "$path"
}

reset_ssh_control_masters() {
    local host path pid

    log "清理可能失效的 SSH ControlMaster"
    for host in "$SSH_PROBE_TARGET" "$JUMP_PROXY_HOST"; do
        [ -n "$host" ] || continue
        path=$(ssh_control_path_for "$host")
        [ -n "$path" ] || continue

        /usr/bin/ssh -o BatchMode=yes -o ConnectTimeout=3 -S "$path" -O exit "$host" >/dev/null 2>&1 &
        pid=$!
        if ! wait_until_exited "$pid" 4; then
            terminate_process_tree "$pid"
        else
            wait "$pid" 2>/dev/null || true
        fi

        ps -axo pid=,command= | awk -v p="$path" 'index($0, p) && index($0, "[mux]") { print $1 }' |
            while IFS= read -r pid; do
                [ -n "$pid" ] || continue
                terminate_process_tree "$pid"
            done

        rm -f "$path" 2>/dev/null || true
    done
}

acquire_lock() {
    if mkdir "$LOCK_DIR" 2>/dev/null; then
        echo "$$" > "${LOCK_DIR}/pid"
        return 0
    fi

    local now lock_mtime lock_age
    now=$(date +%s)
    lock_mtime=$(stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0)
    lock_age=$((now - lock_mtime))

    if [ "$lock_age" -gt "$LOCK_STALE_SECONDS" ]; then
        log "发现过期锁 ${LOCK_DIR} (${lock_age}s), 自动清理"
        rm -rf "$LOCK_DIR"
        if mkdir "$LOCK_DIR" 2>/dev/null; then
            echo "$$" > "${LOCK_DIR}/pid"
            return 0
        fi
    fi

    return 1
}

run_single_kinit_with_timeout() {
    local keychain_password=$1
    local use_renewable=$2
    local -a args=()

    if [ -n "$KINIT_LIFETIME" ]; then
        args+=("-l" "$KINIT_LIFETIME")
    fi
    if [ "$use_renewable" = "yes" ] && [ -n "$KINIT_RENEWABLE_LIFE" ]; then
        args+=("-r" "$KINIT_RENEWABLE_LIFE")
    fi
    args+=("$PRINCIPAL")

    if [ -n "$keychain_password" ]; then
        (printf '%s\n' "$keychain_password" | /usr/bin/kinit "${args[@]}" >/dev/null 2>&1) &
    else
        /usr/bin/kinit "${args[@]}" </dev/null &
    fi
    local pid=$!
    local elapsed=0

    while kill -0 "$pid" 2>/dev/null; do
        if [ "$elapsed" -ge "$KINIT_TIMEOUT_SECONDS" ]; then
            terminate_process_tree "$pid"
            return 124
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    wait "$pid"
}

run_kinit_with_timeout() {
    local keychain_password rc
    keychain_password=$(/usr/bin/security find-generic-password \
        -a "$KINIT_KEYCHAIN_ACCOUNT" \
        -s "$KINIT_KEYCHAIN_SERVICE" \
        -w 2>/dev/null || true)

    if [ -n "$KINIT_RENEWABLE_LIFE" ]; then
        run_single_kinit_with_timeout "$keychain_password" yes
        rc=$?
        if [ "$rc" -eq 0 ]; then
            return 0
        fi
        log "renewable kinit 失败(exit=${rc}, renewable_life=${KINIT_RENEWABLE_LIFE}), 回退普通 kinit"
    fi

    run_single_kinit_with_timeout "$keychain_password" no
}

keychain_password_available() {
    /usr/bin/security find-generic-password \
        -a "$KINIT_KEYCHAIN_ACCOUNT" \
        -s "$KINIT_KEYCHAIN_SERVICE" \
        -w >/dev/null 2>&1
}

save_keychain_password() {
    echo "将保存 ${KINIT_KEYCHAIN_ACCOUNT} 的 kinit 密码到 macOS Keychain。"
    echo "密码不会写入脚本或 shell 历史。"

    local password=""
    local rc
    if [ -t 0 ] && [ -t 1 ]; then
        echo "下一步会由 security 交互式隐藏输入。"
        /usr/bin/security add-generic-password -U \
            -a "$KINIT_KEYCHAIN_ACCOUNT" \
            -s "$KINIT_KEYCHAIN_SERVICE" \
            -l "kinit-refresh password" \
            -j "Used by $LOCAL_HOME/bin/kinit-refresh to refresh Kerberos ticket" \
            -w
        rc=$?
    else
        if ! command -v osascript >/dev/null 2>&1; then
            echo "当前没有交互式终端, 且 osascript 不可用; 请在 Terminal 中运行: kinit-refresh save-password" >&2
            return 1
        fi
        password=$(/usr/bin/osascript \
            -e 'display dialog "输入 REALM Kerberos 密码，保存到 macOS Keychain。" default answer "" with hidden answer buttons {"取消", "保存"} default button "保存" cancel button "取消" with title "kinit-refresh"' \
            -e 'text returned of result')
        rc=$?
        if [ "$rc" -ne 0 ] || [ -z "$password" ]; then
            echo "已取消保存。" >&2
            return 1
        fi
        /usr/bin/security add-generic-password -U \
            -a "$KINIT_KEYCHAIN_ACCOUNT" \
            -s "$KINIT_KEYCHAIN_SERVICE" \
            -l "kinit-refresh password" \
            -j "Used by $LOCAL_HOME/bin/kinit-refresh to refresh Kerberos ticket" \
            -w "$password"
        rc=$?
    fi

    if [ "$rc" -ne 0 ]; then
        echo "保存失败: security 退出码 ${rc}" >&2
        password=""
        return "$rc"
    fi

    echo "已保存到 Keychain, 正在验证 kinit..."
    if [ -n "$password" ]; then
        (printf '%s\n' "$password" | /usr/bin/kinit "$PRINCIPAL" >/dev/null 2>&1)
    else
        run_kinit_with_timeout
    fi
    rc=$?
    password=""
    if [ "$rc" -ne 0 ]; then
        echo "验证失败: kinit 退出码 ${rc}; 已删除刚保存的 Keychain 项" >&2
        /usr/bin/security delete-generic-password \
            -a "$KINIT_KEYCHAIN_ACCOUNT" \
            -s "$KINIT_KEYCHAIN_SERVICE" >/dev/null 2>&1 || true
        return "$rc"
    fi

    echo "验证成功。以后 kinit-refresh 会自动使用 Keychain 中的密码。"
}

delete_keychain_password() {
    /usr/bin/security delete-generic-password \
        -a "$KINIT_KEYCHAIN_ACCOUNT" \
        -s "$KINIT_KEYCHAIN_SERVICE" >/dev/null 2>&1 || true
    echo "已删除 Keychain 中的 kinit-refresh 密码项。"
}

run_with_timeout() {
    local timeout_seconds=$1
    shift
    local output_file="/tmp/kinit-refresh-command.$$.$RANDOM.log"

    "$@" >"$output_file" 2>&1 </dev/null &
    local pid=$!
    local elapsed=0

    while kill -0 "$pid" 2>/dev/null; do
        if [ "$elapsed" -ge "$timeout_seconds" ]; then
            terminate_process_tree "$pid"
            log_command_output "$output_file"
            rm -f "$output_file"
            return 124
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    wait "$pid"
    local rc=$?
    log_command_output "$output_file"
    rm -f "$output_file"
    return "$rc"
}

log_command_output() {
    local output_file=$1

    if [ -s "$output_file" ]; then
        while IFS= read -r line; do
            log "  ${line}"
        done < "$output_file"
    fi
}

log_inline_output() {
    local line

    while IFS= read -r line; do
        [ -n "$line" ] || continue
        log "  ${line}"
    done <<< "$1"
}

monitor_value() {
    local key=$1
    awk -F= -v key="$key" '$1 == key { print substr($0, index($0, "=") + 1); exit }' "$MONITOR_LATEST_FILE" 2>/dev/null || true
}

is_uint() {
    [[ "${1:-}" =~ ^[0-9]+$ ]]
}

verify_ssh_chain() {
    log "预取跳板服务票据: ${JUMP_PROXY_SERVICE}"
    run_with_timeout "$COMMAND_TIMEOUT_SECONDS" /usr/bin/kgetcred "$JUMP_PROXY_SERVICE"
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, kgetcred 退出码 ${rc}"
        return "$rc"
    fi

    log "验证 SSH 链路: ${SSH_PROBE_TARGET}"
    run_with_timeout "$COMMAND_TIMEOUT_SECONDS" /usr/bin/ssh \
        -o BatchMode=yes \
        -o ConnectTimeout=8 \
        -o ConnectionAttempts=1 \
        -o ControlMaster=no \
        -S none \
        -o ServerAliveInterval=5 \
        -o ServerAliveCountMax=1 \
        "$SSH_PROBE_TARGET" true
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, SSH 链路验证退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    return 0
}

verify_codex_chain() {
    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        return 127
    fi

    log "修复 Codex 远端代理链路: ${CODEX_REFRESH_SCRIPT} repair"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" repair
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, Codex 远端代理链路修复退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    log "验证 Codex 远端直连启动与 openai-ok: ${CODEX_REFRESH_SCRIPT} verify"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" verify
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, Codex 远端直连验证退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    return 0
}

verify_codex_chain_fast() {
    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        return 127
    fi

    log "快速修复 Codex Remote GCP 链路: ${CODEX_REFRESH_SCRIPT} repair-fast"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" repair-fast
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, Codex Remote GCP 快速修复退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    log "快速验证 Codex Remote GCP 出海: ${CODEX_REFRESH_SCRIPT} verify-fast"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" verify-fast
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, Codex Remote GCP 快速验证退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    return 0
}

verify_codex_chain_clean_fast() {
    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        return 127
    fi

    log "一键深度修复 Codex Remote GCP 链路: ${CODEX_REFRESH_SCRIPT} deep-repair"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" deep-repair
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        log "失败, Codex Remote GCP 一键深度修复退出码 ${rc}"
        reset_ssh_control_masters
        return "$rc"
    fi

    return 0
}

check_local_codex_official() {
    local app_path="/Applications/Codex.app"
    local codex_path target signature config rc

    rc=0
    log "Smart-Repair: 检查本地 Codex App/CLI 官方性与 provider 污染"

    codex_path="$(command -v codex 2>/dev/null || true)"
    if [ -z "$codex_path" ]; then
        log "警告: PATH 中找不到 codex"
        rc=1
    else
        target="$(readlink "$codex_path" 2>/dev/null || printf '%s' "$codex_path")"
        log "  codex path=${codex_path} target=${target}"
        case "$target" in
            /Applications/Codex.app/Contents/Resources/codex|"$app_path"/Contents/Resources/codex)
                ;;
            *)
                log "警告: codex CLI 不是来自 /Applications/Codex.app/Contents/Resources/codex"
                rc=1
                ;;
        esac
    fi

    if [ ! -d "$app_path" ]; then
        log "警告: ${app_path} 不存在"
        rc=1
    else
        signature="$(codesign -dv --verbose=4 "$app_path" 2>&1 || true)"
        if ! grep -q 'Identifier=com.openai.codex' <<< "$signature"; then
            log "警告: Codex.app bundle identifier 不是 com.openai.codex"
            rc=1
        fi
        if ! grep -q 'Authority=Developer ID Application: OpenAI OpCo, LLC' <<< "$signature"; then
            log "警告: Codex.app 签名不是 OpenAI OpCo, LLC"
            rc=1
        fi
        if ! spctl --assess --type execute "$app_path" >/dev/null 2>&1; then
            log "警告: Codex.app 未通过 macOS notarized Developer ID 校验"
            rc=1
        fi
    fi

    config="$LOCAL_HOME/.codex/config.toml"
    if [ -f "$config" ]; then
        if grep -Eiq '^[[:space:]]*model_provider[[:space:]]*=|^[[:space:]]*\[model_providers\.|^[[:space:]]*base_url[[:space:]]*=|OPENAI_BASE_URL|aidp\.bytedance\.net|^[[:space:]]*CODEX_HOME[[:space:]]*=.*codex-modelhub|127\.0\.0\.1:18080|127\.0\.0\.1:18081|custom-provider' "$config"; then
            log "警告: ${config} 存在 custom/modelhub/provider 相关配置"
            rc=1
        else
            log "  ${config} 未发现 modelhub/custom provider 污染"
        fi
    fi

    case "${CODEX_HOME:-}" in
        ""|"$LOCAL_HOME/.codex")
            ;;
        *)
            log "警告: 当前进程环境 CODEX_HOME=${CODEX_HOME}; 从该 shell 启动 codex 会读取非官方家目录"
            ;;
    esac

    return "$rc"
}

run_monitor_sample() {
    if [ ! -x "$CODEX_MONITOR_SCRIPT" ]; then
        log "跳过 monitor sample, 脚本不存在或不可执行: $CODEX_MONITOR_SCRIPT"
        return 127
    fi

    log "采样 Codex GCP 状态: ${CODEX_MONITOR_SCRIPT} sample"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_MONITOR_SCRIPT" sample
}

run_codex_repair_command() {
    local command=$1
    local reason=$2
    local rc

    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        return 127
    fi

    log "Smart-Repair 选择: ${command} (${reason})"
    write_status "running" "ok" "checking" "checking" "$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')" "智能修复: ${reason}"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" "$command"
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "Smart-Repair 步骤失败: ${command}, 退出码 ${rc}"
    fi
    return "$rc"
}

smart_refresh_ssh_if_needed() {
    local exp rc
    exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')

    if keychain_password_available; then
        log "Smart-Repair: 检测到 Keychain kinit 密码, 刷新 Kerberos ticket"
        run_kinit_with_timeout
        rc=$?
        if [ "$rc" -ne 0 ]; then
            log "Smart-Repair: kinit 刷新失败, 退出码 ${rc}"
            write_status "fail" "fail" "unknown" "unknown" "$exp" "智能修复失败: kinit 刷新失败"
            return "$rc"
        fi
        exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    elif ! klist -s 2>/dev/null; then
        log "Smart-Repair: 当前无有效 Kerberos ticket, 且 Keychain 未保存密码"
        write_status "fail" "no_ticket" "unknown" "unknown" "$exp" "智能修复失败: 无有效 Kerberos ticket"
        return 1
    else
        log "Smart-Repair: 使用当前有效 Kerberos ticket 验证 SSH"
    fi

    verify_ssh_chain
}

smart_reset_cursor_if_needed() {
    local output rc

    [ -x "$CURSOR_RESET_SCRIPT" ] || return 0
    output="$("$CURSOR_RESET_SCRIPT" status 2>&1 || true)"
    log "Smart-Repair: Cursor Remote SSH 状态"
    log_inline_output "$output"
    if ! grep -q 'would terminate Cursor Remote SSH process' <<< "$output"; then
        return 0
    fi

    log "Smart-Repair: 发现卡住的 Cursor Remote SSH 进程或转发, 只重置 Cursor SSH"
    run_with_timeout "$COMMAND_TIMEOUT_SECONDS" "$CURSOR_RESET_SCRIPT" reset
    rc=$?
    if [ "$rc" -eq 0 ]; then
        SMART_REPAIR_CURSOR_RESET=1
    fi
    return "$rc"
}

smart_monitor_status_message() {
    printf 'status=%s cause=%s local1080=%s/%s local7890=%s/%s remote10800=%s/%s stale10800=%s danger10800=%s chatgpt=%s' \
        "$(monitor_value STATUS)" \
        "$(monitor_value CAUSE)" \
        "$(monitor_value LOCAL_1080_COUNT)" \
        "$(monitor_value LOCAL_1080_IP)" \
        "$(monitor_value LOCAL_7890_COUNT)" \
        "$(monitor_value LOCAL_7890_IP)" \
        "$(monitor_value REMOTE_10800_COUNT)" \
        "$(monitor_value REMOTE_10800_IP)" \
        "$(monitor_value REMOTE_10800_STALE_SOCKET_COUNT)" \
        "$(monitor_value REMOTE_10800_DANGER_STALE_SOCKET_COUNT)" \
        "$(monitor_value CHATGPT_CODE)"
}

smart_sample_and_log() {
    local rc

    run_monitor_sample
    rc=$?
    log "Smart-Repair monitor: $(smart_monitor_status_message)"
    return "$rc"
}

smart_select_repair_command() {
    local status cause stale_count danger_stale_count
    status="$(monitor_value STATUS)"
    cause="$(monitor_value CAUSE)"
    stale_count="$(monitor_value REMOTE_10800_STALE_SOCKET_COUNT)"
    danger_stale_count="$(monitor_value REMOTE_10800_DANGER_STALE_SOCKET_COUNT)"
    is_uint "$stale_count" || stale_count=0
    is_uint "$danger_stale_count" || danger_stale_count=0

    if [ "$status" = "ok" ] && [ "$danger_stale_count" -ge "$SMART_REPAIR_STALE_SOCKET_THRESHOLD" ]; then
        SMART_REPAIR_COMMAND="repair-remote-sockets"
        SMART_REPAIR_REASON="10800 dangerous stale socket 数过高 (${danger_stale_count}), 只重建远端 forward/socket 层"
        return 0
    fi

    case "$cause" in
        ok)
            SMART_REPAIR_COMMAND="none"
            SMART_REPAIR_REASON="monitor 已经为 ok, 不重建 GCP 链路"
            ;;
        gcp_tcp_fail|local_1080_missing|local_1080_bad_egress)
            SMART_REPAIR_COMMAND="repair-local-socks"
            SMART_REPAIR_REASON="本地 1080 SOCKS/GCP TCP 异常, 只修复本地 SOCKS 层"
            ;;
        local_7890_missing|local_7890_bad_egress)
            SMART_REPAIR_COMMAND="repair-local-http"
            SMART_REPAIR_REASON="本地 7890 HTTP 代理异常, 只修复本地 HTTP 层"
            ;;
        remote_10800_missing|remote_10800_bad_egress|chatgpt_unreachable_*)
            SMART_REPAIR_COMMAND="repair-remote-forward"
            SMART_REPAIR_REASON="远端 10800 或 ChatGPT data plane 异常, 只修复远端 forward 层"
            ;;
        remote_ssh_fail_*)
            SMART_REPAIR_COMMAND="ssh-refresh"
            SMART_REPAIR_REASON="远端 SSH 采样失败, 刷新 Kerberos/SSH 后重新采样"
            ;;
        *)
            SMART_REPAIR_COMMAND="repair-fast"
            SMART_REPAIR_REASON="未知 monitor cause=${cause:-empty}, 使用保守快速修复"
            ;;
    esac
}

smart_verify_versions_if_needed() {
    local rc

    [ "$SMART_REPAIR_CHECK_VERSION" = "1" ] || return 0
    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        return 127
    fi

    log "Smart-Repair: 检查本地/远端 Codex 版本和 remote wrapper"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" version-status
    rc=$?
    if [ "$rc" -eq 0 ]; then
        return 0
    fi
    if [ "$rc" -eq 42 ]; then
        log "Smart-Repair: 检测到远端 Codex runtime 仍在运行升级前的 CLI, 只重启远端 app-server"
        run_codex_repair_command restart-remote-app-server "远端 Codex CLI 已升级但 app-server runtime 仍是旧进程"
        return "$?"
    fi

    log "Smart-Repair: 检测到版本或 wrapper drift, 先执行轻量 wrapper 修复"
    run_codex_repair_command repair-wrappers "本地/远端 Codex wrapper 或 proxy.env 漂移"
    rc=$?
    if [ "$rc" -eq 0 ]; then
        return 0
    fi

    log "Smart-Repair: wrapper 修复后仍不一致, 才升级到 deep-repair"
    run_codex_repair_command deep-repair "本地/远端 Codex 版本不一致或 wrapper 修复失败"
}

smart_repair() {
    local exp rc command status cause

    SMART_REPAIR_CURSOR_RESET=0
    SMART_REPAIR_COMMAND=""
    SMART_REPAIR_REASON=""
    exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    log "kinit-refresh Smart-Repair 启动 (codex_timeout=${CODEX_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
    write_status "running" "checking" "checking" "checking" "$exp" "正在智能诊断并选择最小修复动作"

    smart_reset_cursor_if_needed
    rc=$?
    if [ "$rc" -ne 0 ]; then
        write_status "fail" "unknown" "unknown" "unknown" "$exp" "智能修复失败: Cursor SSH reset 退出码 ${rc}"
        return "$rc"
    fi

    if ! check_local_codex_official; then
        log "Smart-Repair: 本地 Codex 官方性检查存在警告, 继续检查 GCP 链路"
    fi

    smart_sample_and_log || true
    smart_select_repair_command
    command="$SMART_REPAIR_COMMAND"
    if [ "$command" = "ssh-refresh" ]; then
        write_status "running" "checking" "unknown" "unknown" "$exp" "智能修复: SSH 采样失败, 正在刷新 Kerberos/SSH"
        smart_refresh_ssh_if_needed
        rc=$?
        if [ "$rc" -ne 0 ]; then
            write_status "fail" "fail" "unknown" "unknown" "$exp" "智能修复失败: SSH 链路不可用"
            return "$rc"
        fi
        smart_sample_and_log || true
        smart_select_repair_command
        command="$SMART_REPAIR_COMMAND"
    fi

    if [ "$command" != "none" ]; then
        run_codex_repair_command "$command" "$SMART_REPAIR_REASON"
        rc=$?
        if [ "$rc" -ne 0 ]; then
            case "$(monitor_value CAUSE)" in
                gcp_tcp_fail)
                    write_status "fail" "ok" "fail" "fail" "$exp" "智能修复失败: GCP TCP 不通, 需要检查本地网络/VPN/GCP"
                    return "$rc"
                    ;;
            esac
            run_codex_repair_command repair-fast "目标修复失败, 回退快速修复"
            rc=$?
            if [ "$rc" -ne 0 ]; then
                run_codex_repair_command deep-repair "快速修复仍失败, 才执行深度修复"
                rc=$?
                [ "$rc" -eq 0 ] || return "$rc"
            fi
        fi
    else
        log "Smart-Repair: ${SMART_REPAIR_REASON}"
    fi

    smart_sample_and_log || true
    status="$(monitor_value STATUS)"
    cause="$(monitor_value CAUSE)"
    if [ "$status" != "ok" ]; then
        run_codex_repair_command repair-fast "采样仍未恢复 (${cause:-unknown}), 回退快速修复"
        rc=$?
        if [ "$rc" -ne 0 ]; then
            run_codex_repair_command deep-repair "快速修复后仍未恢复, 才执行深度修复"
            rc=$?
            [ "$rc" -eq 0 ] || return "$rc"
        fi
        smart_sample_and_log || true
        status="$(monitor_value STATUS)"
        cause="$(monitor_value CAUSE)"
    fi

    if [ "$status" = "ok" ]; then
        local stale_count
        stale_count="$(monitor_value REMOTE_10800_STALE_SOCKET_COUNT)"
        is_uint "$stale_count" || stale_count=0
        if [ "$stale_count" -ge "$SMART_REPAIR_STALE_SOCKET_THRESHOLD" ]; then
            run_codex_repair_command repair-remote-sockets "GCP 已恢复但远端 10800 stale socket 仍过高 (${stale_count})"
            rc=$?
            [ "$rc" -eq 0 ] || return "$rc"
            smart_sample_and_log || true
            status="$(monitor_value STATUS)"
            cause="$(monitor_value CAUSE)"
        fi
    fi

    if [ "$status" = "ok" ]; then
        smart_verify_versions_if_needed
        rc=$?
        if [ "$rc" -ne 0 ]; then
            write_status "fail" "ok" "fail" "fail" "$exp" "智能修复失败: 版本/wrapper 深度修复失败"
            return "$rc"
        fi
        smart_sample_and_log || true
    fi

    status="$(monitor_value STATUS)"
    cause="$(monitor_value CAUSE)"
    exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    if [ "$status" = "ok" ]; then
        mark_gcp_enabled
        if [ "$SMART_REPAIR_CURSOR_RESET" = "1" ]; then
            write_status "ok" "ok" "ok" "ok" "$exp" "智能修复完成: Cursor SSH 已重置, GCP 链路正常"
        else
            write_status "ok" "ok" "ok" "ok" "$exp" "智能修复完成: GCP 链路正常"
        fi
        log "Smart-Repair 成功: $(smart_monitor_status_message)"
        return 0
    fi

    case "$cause" in
        remote_10800_*|chatgpt_unreachable_*)
            run_codex_repair_command repair-remote-sockets "最终采样仍显示远端 10800/ChatGPT 异常 (${cause:-unknown}), 再次只重置 forward/socket 层"
            rc=$?
            [ "$rc" -eq 0 ] || return "$rc"
            smart_sample_and_log || true
            status="$(monitor_value STATUS)"
            cause="$(monitor_value CAUSE)"
            exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
            if [ "$status" = "ok" ]; then
                mark_gcp_enabled
                write_status "ok" "ok" "ok" "ok" "$exp" "智能修复完成: 远端 10800 已重建, GCP 链路正常"
                log "Smart-Repair 成功: $(smart_monitor_status_message)"
                return 0
            fi
            ;;
    esac

    log "Smart-Repair 最终失败: status=${status:-empty}, cause=${cause:-empty}"
    write_status "fail" "ok" "fail" "fail" "$exp" "智能修复失败: ${cause:-unknown}"
    return 1
}

recover_flap() {
    local exp rc status cause danger_stale_count

    exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    log "Recover-Flap 启动 (codex_timeout=${CODEX_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
    write_status "running" "ok" "checking" "checking" "$exp" "一键恢复波动: 正在执行最小恢复快照"

    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "Recover-Flap 失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        write_status "fail" "ok" "fail" "fail" "$exp" "一键恢复波动失败: 修复脚本不存在"
        return 127
    fi

    log "Recover-Flap: 先执行 debug-fast, 只在链路破损时做最小修复"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" debug-fast
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "Recover-Flap: debug-fast 退出码 ${rc}, 继续进入 smart-repair 精准恢复"
    fi

    smart_sample_and_log || true
    status="$(monitor_value STATUS)"
    cause="$(monitor_value CAUSE)"
    danger_stale_count="$(monitor_value REMOTE_10800_DANGER_STALE_SOCKET_COUNT)"
    is_uint "$danger_stale_count" || danger_stale_count=0

    if [ "$status" != "ok" ]; then
        log "Recover-Flap: monitor 仍异常 (${cause:-unknown}), 进入 smart-repair"
        smart_repair
        rc=$?
        [ "$rc" -eq 0 ] || return "$rc"
    elif [ "$danger_stale_count" -ge "$SMART_REPAIR_STALE_SOCKET_THRESHOLD" ]; then
        run_codex_repair_command repair-remote-sockets "GCP 可用但远端 10800 dangerous stale socket 过高 (${danger_stale_count})"
        rc=$?
        [ "$rc" -eq 0 ] || return "$rc"
    else
        log "Recover-Flap: monitor 已恢复, 无需额外修复"
    fi

    write_status "running" "ok" "checking" "checking" "$exp" "一键恢复波动: 正在最终验证 GCP 出口"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" verify-fast
    rc=$?
    if [ "$rc" -ne 0 ]; then
        log "Recover-Flap: verify-fast 失败 (${rc}), 再执行一轮 smart-repair 后复验"
        smart_repair
        rc=$?
        [ "$rc" -eq 0 ] || return "$rc"
        run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" verify-fast
        rc=$?
        [ "$rc" -eq 0 ] || return "$rc"
    fi

    smart_sample_and_log || true
    status="$(monitor_value STATUS)"
    cause="$(monitor_value CAUSE)"
    exp=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    if [ "$status" = "ok" ]; then
        mark_gcp_enabled
        write_status "ok" "ok" "ok" "ok" "$exp" "一键恢复波动完成: GCP 链路正常"
        log "Recover-Flap 成功: $(smart_monitor_status_message)"
        return 0
    fi

    log "Recover-Flap 最终失败: status=${status:-empty}, cause=${cause:-empty}"
    write_status "fail" "ok" "fail" "fail" "$exp" "一键恢复波动失败: ${cause:-unknown}"
    return 1
}

stop_codex_gcp_egress() {
    if [ ! -x "$CODEX_REFRESH_SCRIPT" ]; then
        log "失败, Codex 修复脚本不存在或不可执行: $CODEX_REFRESH_SCRIPT"
        return 127
    fi

    log "停止并限流 Codex Remote GCP 出口: ${CODEX_REFRESH_SCRIPT} limit-egress"
    run_with_timeout "$CODEX_TIMEOUT_SECONDS" "$CODEX_REFRESH_SCRIPT" limit-egress
}

mark_gcp_enabled() {
    mkdir -p "$STATE_DIR"
    date '+%Y-%m-%d %H:%M:%S' > "$GCP_ENABLED_FILE"
}

mark_gcp_disabled() {
    rm -f "$GCP_ENABLED_FILE" 2>/dev/null || true
}

dry_run_plan() {
    local mode=$1

    echo "DRY RUN: kinit-refresh ${mode}"
    echo "No Kerberos refresh, SSH probe, status write, marker update, proxy repair, or process cleanup will run."

    case "$mode" in
        smart-repair)
            cat <<EOF
Would:
  - check for stuck Cursor Remote SSH install/tunnel process groups and reset only those if present
  - verify local Codex.app is signed by OpenAI and ~/.codex has no custom/modelhub provider override
  - run codex-gcp-monitor sample and read ${MONITOR_LATEST_FILE}
  - refresh Kerberos/SSH only if monitor reports a remote SSH failure
  - choose the smallest matching GCP repair:
      local_1080_missing/local_1080_bad/gcp -> codex-gcp-remote --dry-run repair-local-socks
      local_7890_missing/local_7890_bad     -> codex-gcp-remote --dry-run repair-local-http
      remote_10800/chatgpt data-plane issue -> codex-gcp-remote --dry-run repair-remote-forward
      many stale remote 10800 sockets       -> codex-gcp-remote --dry-run repair-remote-sockets
      stale remote Codex runtime            -> codex-gcp-remote --dry-run restart-remote-app-server
      version/wrapper drift                 -> codex-gcp-remote --dry-run deep-repair
  - avoid restarting remote Codex app-server except for explicit stale runtime or deep repair
EOF
            ;;
        recover-flap)
            cat <<EOF
Would:
  - run codex-gcp-remote --dry-run debug-fast as the smallest live-path snapshot/repair
  - sample codex-gcp-monitor and classify local 1080, local 7890, remote 10800, ChatGPT, and socket storm state
  - run smart-repair only if the monitor is still unhealthy
  - clear dangerous remote 10800 stale sockets only after the local data plane is healthy
  - finish with codex-gcp-remote --dry-run verify-fast and a final monitor sample
EOF
            CODEX_GCP_DRY_RUN=1 "$CODEX_REFRESH_SCRIPT" --dry-run debug-fast 2>/dev/null || true
            ;;
        stop-gcp)
            echo "Would run: codex-gcp-remote --dry-run limit-egress"
            CODEX_GCP_DRY_RUN=1 "$CODEX_REFRESH_SCRIPT" --dry-run limit-egress 2>/dev/null || true
            ;;
        ssh-only)
            cat <<EOF
Would:
  - refresh Kerberos using Keychain password if available
  - prefetch jump service credentials with kgetcred
  - probe SSH target ${SSH_PROBE_TARGET}
  - leave Codex Remote GCP untouched
EOF
            ;;
        remote-gcp)
            echo "Would run: codex-gcp-remote --dry-run deep-repair"
            CODEX_GCP_DRY_RUN=1 "$CODEX_REFRESH_SCRIPT" --dry-run deep-repair 2>/dev/null || true
            ;;
        remote-gcp-full)
            echo "Would probe SSH, then run: codex-gcp-remote --dry-run repair, then verify"
            CODEX_GCP_DRY_RUN=1 "$CODEX_REFRESH_SCRIPT" --dry-run repair 2>/dev/null || true
            ;;
        full)
            echo "Would refresh Kerberos, verify SSH, then run: codex-gcp-remote --dry-run repair, then verify"
            CODEX_GCP_DRY_RUN=1 "$CODEX_REFRESH_SCRIPT" --dry-run repair 2>/dev/null || true
            ;;
    esac
}

case "${1:-}" in
    status)
        klist 2>&1
        rc=$?
        if [ -f "$STATUS_FILE" ]; then
            echo
            cat "$STATUS_FILE"
        fi
        exit $rc
        ;;
    log)
        if [ -f "$LOG_FILE" ]; then
            tail -n 50 "$LOG_FILE"
        else
            echo "暂无日志: $LOG_FILE"
        fi
        exit 0
        ;;
    save-password|store-password|keychain-save)
        if [ "$DRY_RUN" = "1" ]; then
            echo "DRY RUN: would prompt for Kerberos password and save/update the Keychain item ${KINIT_KEYCHAIN_SERVICE}/${KINIT_KEYCHAIN_ACCOUNT}"
            exit 0
        fi
        save_keychain_password
        exit $?
        ;;
    delete-password|forget-password|keychain-delete)
        if [ "$DRY_RUN" = "1" ]; then
            echo "DRY RUN: would delete the Keychain item ${KINIT_KEYCHAIN_SERVICE}/${KINIT_KEYCHAIN_ACCOUNT}"
            exit 0
        fi
        delete_keychain_password
        exit 0
        ;;
    ssh|ssh-only|refresh-ssh)
        MODE="ssh-only"
        ;;
    smart|smart-repair|one-click|oneclick|fix|repair)
        MODE="smart-repair"
        ;;
    recover-flap|flap|one-click-recover|recover|perfect-recover)
        MODE="recover-flap"
        ;;
    stop-gcp|stop-egress|limit-gcp|limit-egress)
        MODE="stop-gcp"
        ;;
    gcp|remote-gcp|codex-gcp|refresh-gcp|gcp-clean|remote-gcp-clean|codex-gcp-clean|refresh-gcp-clean)
        MODE="remote-gcp"
        ;;
    gcp-full|remote-gcp-full|codex-gcp-full|refresh-gcp-full)
        MODE="remote-gcp-full"
        ;;
    "")
        MODE="full"
        ;;
    *)
        echo "Usage: kinit-refresh [--dry-run] [status|log|save-password|delete-password|ssh-only|smart-repair|recover-flap|remote-gcp|stop-gcp]" >&2
        exit 2
        ;;
esac

if [ "$DRY_RUN" = "1" ]; then
    dry_run_plan "$MODE"
    exit 0
fi

if ! acquire_lock; then
    RUNNING_PID=$(cat "${LOCK_DIR}/pid" 2>/dev/null || echo "unknown")
    log "已有刷新任务在运行(pid=${RUNNING_PID}), 本次跳过"
    write_status "running" "unknown" "unknown" "unknown" "" "已有刷新任务在运行(pid=${RUNNING_PID})"
    [ -t 1 ] && echo "已有刷新任务在运行, 本次跳过"
    exit 0
fi

trap cleanup EXIT

if [ "$MODE" = "smart-repair" ]; then
    smart_repair
    RC=$?
    if [ "$RC" -eq 0 ]; then
        [ -t 1 ] && echo "智能修复完成"
    else
        [ -t 1 ] && echo "智能修复失败 (exit ${RC}), 详见 ${LOG_FILE}"
    fi
    exit "$RC"
fi

if [ "$MODE" = "recover-flap" ]; then
    recover_flap
    RC=$?
    if [ "$RC" -eq 0 ]; then
        [ -t 1 ] && echo "一键恢复波动完成"
    else
        [ -t 1 ] && echo "一键恢复波动失败 (exit ${RC}), 详见 ${LOG_FILE}"
    fi
    exit "$RC"
fi

if [ "$MODE" = "stop-gcp" ]; then
    EXP=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    log "kinit-refresh stop-gcp 启动 (codex_timeout=${CODEX_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
    write_status "running" "ok" "stopping" "stopping" "$EXP" "正在停止 Codex Remote GCP 出口并清理 stale worker"

    stop_codex_gcp_egress
    RC=$?
    if [ "$RC" -eq 0 ]; then
        mark_gcp_disabled
        log "成功, Codex Remote GCP 出口已停止, stale worker 已清理"
        write_status "stopped" "ok" "stopped" "stopped" "$EXP" "GCP出口已停止；本地1080/7890关闭，远端stale codex exec已清理"
        [ -t 1 ] && echo "GCP 出口已停止"
        exit 0
    fi

    log "stop-gcp 失败, 退出码 ${RC}"
    write_status "warning" "ok" "unknown" "unknown" "$EXP" "停止 GCP 出口未完全验证, 退出码 ${RC}"
    [ -t 1 ] && echo "GCP 出口停止未完全验证 (exit ${RC}), 详见 ${LOG_FILE}"
    exit "$RC"
fi

if [ "$MODE" = "ssh-only" ]; then
    EXP=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    log "kinit-refresh SSH-only 启动 (attempts=${MAX_ATTEMPTS}, command_timeout=${COMMAND_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
    write_status "running" "checking" "skipped" "skipped" "$EXP" "正在验证与刷新 SSH 链路"

    if keychain_password_available; then
        log "检测到 Keychain 中的 kinit 密码, 先刷新 Kerberos ticket"
        run_kinit_with_timeout
        RC=$?
        if [ "$RC" -ne 0 ]; then
            log "SSH-only 失败, kinit 刷新退出码 ${RC}"
            write_status "fail" "fail" "skipped" "skipped" "$EXP" "kinit 刷新失败, 退出码 ${RC}"
            exit "$RC"
        fi
        EXP=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
        write_status "running" "checking" "skipped" "skipped" "$EXP" "ticket 已刷新, 正在验证 SSH 链路"
    elif ! klist -s 2>/dev/null; then
        log "SSH-only 失败, 当前无有效 Kerberos ticket; 请在终端手动执行 kinit"
        write_status "fail" "no_ticket" "skipped" "skipped" "$EXP" "无有效 Kerberos ticket; 请在终端手动 kinit"
        exit 1
    else
        log "未检测到 Keychain kinit 密码, 使用当前有效 ticket 验证 SSH"
    fi

    attempt=1
    RC=1
    while [ "$attempt" -le "$MAX_ATTEMPTS" ]; do
        log "第 ${attempt}/${MAX_ATTEMPTS} 次 SSH 刷新尝试"
        verify_ssh_chain
        RC=$?
        if [ "$RC" -eq 0 ]; then
            log "成功, 当前 Kerberos ticket 与 SSH 链路均可用; 未刷新 Codex Remote GCP"
            write_status "ok" "ok" "skipped" "skipped" "$EXP" "SSH 链路可用; 未检查 Codex Remote GCP"
            [ -t 1 ] && echo "SSH 刷新成功, ticket 有效期至: ${EXP}"
            exit 0
        fi

        if [ "$RC" -eq 124 ]; then
            log "注意: SSH 链路探活超时, 将快速重试"
            write_status "warning" "timeout" "skipped" "skipped" "$EXP" "SSH 链路探活超时"
        else
            log "注意: SSH 链路探活失败, 将快速重试"
            write_status "warning" "fail" "skipped" "skipped" "$EXP" "SSH 链路探活失败"
        fi

        if [ "$attempt" -lt "$MAX_ATTEMPTS" ]; then
            log "${RETRY_DELAY_SECONDS}s 后重试"
            sleep "$RETRY_DELAY_SECONDS"
        fi

        attempt=$((attempt + 1))
    done

    log "SSH-only 最终失败, 已完成 ${MAX_ATTEMPTS} 次尝试"
    write_status "fail" "fail" "skipped" "skipped" "$EXP" "SSH 刷新最终失败"
    [ -t 1 ] && echo "SSH 刷新失败 (exit ${RC}), 详见 ${LOG_FILE}"
    exit "$RC"
fi

if [ "$MODE" = "remote-gcp" ] || [ "$MODE" = "remote-gcp-full" ]; then
    EXP=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
    log "kinit-refresh Remote-GCP 启动 (mode=${MODE}, codex_timeout=${CODEX_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
    write_status "running" "checking" "checking" "checking" "$EXP" "正在刷新 Codex Remote GCP 链路"

    if [ "$MODE" = "remote-gcp-full" ]; then
        verify_ssh_chain
        RC=$?
        if [ "$RC" -ne 0 ]; then
            log "Remote-GCP full 失败, SSH 链路不可用, 退出码 ${RC}; 可先执行 SSH 刷新"
            write_status "fail" "fail" "unknown" "unknown" "$EXP" "SSH 链路不可用; 请先刷新 SSH"
            exit "$RC"
        fi

        write_status "running" "ok" "checking" "checking" "$EXP" "SSH 可用, 正在执行完整 Codex Remote GCP repair+verify"
        verify_codex_chain
    else
        write_status "running" "checking" "checking" "checking" "$EXP" "正在一键强制修复 Codex Remote GCP 链路"
        verify_codex_chain_clean_fast
    fi
    RC=$?
    if [ "$RC" -eq 0 ]; then
        mark_gcp_enabled
        log "成功, Codex Remote GCP ${MODE} repair+verify 均可用"
        write_status "ok" "ok" "ok" "ok" "$EXP" "Codex Remote GCP ${MODE} 成功"
        [ -t 1 ] && echo "Remote GCP 刷新成功"
        exit 0
    fi

    log "Remote-GCP 失败, Codex repair/verify 退出码 ${RC}"
    write_status "fail" "ok" "fail" "fail" "$EXP" "Codex Remote GCP repair/verify 失败, 退出码 ${RC}"
    [ -t 1 ] && echo "Remote GCP 刷新失败 (exit ${RC}), 详见 ${LOG_FILE}"
    exit "$RC"
fi

log "kinit-refresh 启动 (principal=${PRINCIPAL}, attempts=${MAX_ATTEMPTS}, kinit_timeout=${KINIT_TIMEOUT_SECONDS}s, command_timeout=${COMMAND_TIMEOUT_SECONDS}s, codex_timeout=${CODEX_TIMEOUT_SECONDS}s, ssh_probe=${SSH_PROBE_TARGET})"
write_status "running" "checking" "checking" "checking" "" "正在刷新 Kerberos、SSH 与 Codex 链路"

attempt=1
RC=1
EXP=""
while [ "$attempt" -le "$MAX_ATTEMPTS" ]; do
    STATUS_WRITTEN=0
    log "第 ${attempt}/${MAX_ATTEMPTS} 次刷新尝试"
    run_kinit_with_timeout
    RC=$?

    if [ "$RC" -eq 0 ]; then
        EXP=$(klist 2>/dev/null | awk '/krbtgt/ {print $5, $6, $7, $8; exit}')
        log "kinit 成功, ticket 有效期至: ${EXP}"
        write_status "running" "checking" "checking" "checking" "$EXP" "ticket 已刷新, 正在验证 SSH 链路"

        verify_ssh_chain
        RC=$?
        if [ "$RC" -eq 0 ]; then
            log "SSH 链路可用, 继续验证 Codex 出海链路"
            write_status "running" "ok" "checking" "checking" "$EXP" "ticket 已刷新, SSH 可用, 正在验证 Codex 出海链路"

            verify_codex_chain
            RC=$?
            if [ "$RC" -eq 0 ]; then
                log "成功, Kerberos ticket、SSH 链路与 Codex 出海链路均可用"
                write_status "ok" "ok" "ok" "ok" "$EXP" "Kerberos、SSH 与 Codex 出海链路均可用"
                [ -t 1 ] && echo "刷新成功, 远端 SSH 与 Codex 均可用, ticket 有效期至: ${EXP}"
                exit 0
            fi

            if [ "$RC" -eq 124 ]; then
                log "注意: ticket 与 SSH 已可用, 但 Codex 出海链路探活超时, 将快速重试"
                write_status "warning" "ok" "fail" "fail" "$EXP" "ticket 与 SSH 可用, 但 Codex 出海链路探活超时"
            else
                log "注意: ticket 与 SSH 已可用, 但 Codex 出海链路探活失败, 将快速重试"
                write_status "warning" "ok" "fail" "fail" "$EXP" "ticket 与 SSH 可用, 但 Codex 出海链路失败"
            fi
        else
            if [ "$RC" -eq 124 ]; then
                log "注意: ticket 已刷新, 但 SSH 链路探活超时, 将快速重试"
                write_status "warning" "timeout" "unknown" "unknown" "$EXP" "ticket 已刷新, 但 SSH 链路探活超时"
            else
                log "注意: kinit 已成功但 SSH 链路探活失败, 将快速重试; ticket 仍已刷新"
                write_status "warning" "fail" "unknown" "unknown" "$EXP" "ticket 已刷新, 但 SSH 链路探活失败"
            fi
        fi
        STATUS_WRITTEN=1
    fi

    if [ "$STATUS_WRITTEN" -eq 0 ]; then
        if [ "$RC" -eq 124 ]; then
            log "失败, 命令超过超时时间未返回, 已终止"
            write_status "fail" "timeout" "unknown" "unknown" "$EXP" "刷新或链路探活超时"
        else
            log "失败, 退出码 ${RC}"
            write_status "fail" "fail" "fail" "fail" "$EXP" "刷新失败, 退出码 ${RC}"
        fi
    fi

    if [ "$attempt" -lt "$MAX_ATTEMPTS" ]; then
        log "${RETRY_DELAY_SECONDS}s 后重试"
        sleep "$RETRY_DELAY_SECONDS"
    fi

    attempt=$((attempt + 1))
done

log "最终失败, 已完成 ${MAX_ATTEMPTS} 次尝试"
write_status "fail" "fail" "fail" "fail" "$EXP" "最终失败, 已完成 ${MAX_ATTEMPTS} 次尝试"
[ -t 1 ] && echo "刷新失败 (exit ${RC}), 详见 ${LOG_FILE}"
exit "$RC"
