#!/usr/bin/env bash
set -Eeuo pipefail

LOCAL_USER="$(id -un)"
LOCAL_HOME="${LOCAL_HOME:-$(dscl . -read "/Users/${LOCAL_USER}" NFSHomeDirectory 2>/dev/null | awk '{ print $2; exit }')}"
LOCAL_HOME="${LOCAL_HOME:-$HOME}"
export HOME="$LOCAL_HOME"

CONFIG_FILE="${CODEX_GCP_REFRESH_CONFIG:-$LOCAL_HOME/.config/codex-gcp-refresh/config.env}"
if [[ -f "$CONFIG_FILE" ]]; then
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
fi

GCP_HOST="${GCP_HOST:-192.0.2.10}"
GCP_USER="${GCP_USER:-gcp-user}"
GCP_PORT="${GCP_PORT:-443}"
GCP_KEY="${GCP_KEY:-$LOCAL_HOME/.ssh/google_compute_engine}"
GCP_EXPECTED_IP="${GCP_EXPECTED_IP:-192.0.2.10}"
GCP_SSH_KEX_ALGORITHMS="${GCP_SSH_KEX_ALGORITHMS:-curve25519-sha256}"
GCP_SSH_HOST_KEY_ALGORITHMS="${GCP_SSH_HOST_KEY_ALGORITHMS:-ssh-ed25519}"
GCP_SSH_CIPHERS="${GCP_SSH_CIPHERS:-chacha20-poly1305@openssh.com}"
LOCAL_SOCKS_HOST="${LOCAL_SOCKS_HOST:-127.0.0.1}"
LOCAL_SOCKS_PORT="${LOCAL_SOCKS_PORT:-1080}"
IP_CHECK_URL="${IP_CHECK_URL:-${MONITOR_IP_CHECK_URL:-http://api.ipify.org}}"
IP_CHECK_TIMEOUT="${IP_CHECK_TIMEOUT:-15}"
SOCKS_HEALTH_INTERVAL_SECONDS="${SOCKS_HEALTH_INTERVAL_SECONDS:-30}"
SOCKS_HEALTH_FAILURE_THRESHOLD="${SOCKS_HEALTH_FAILURE_THRESHOLD:-6}"
SOCKS_HEALTH_PROBE_ATTEMPTS="${SOCKS_HEALTH_PROBE_ATTEMPTS:-3}"
SOCKS_HEALTH_PROBE_DELAY_SECONDS="${SOCKS_HEALTH_PROBE_DELAY_SECONDS:-2}"
STATE_DIR="${STATE_DIR:-$LOCAL_HOME/.codex-gcp-tunnel}"

mkdir -p "$STATE_DIR"
printf '%s\n' "$$" > "$STATE_DIR/gcp-socks.launchd.pid"

route_field() {
  local target="$1"
  local field="$2"
  route -n get "$target" 2>/dev/null | awk -v f="$field" '$1 == f ":" { print $2; exit }'
}

bind_address() {
  if [[ -n "${GCP_BIND_ADDRESS:-}" ]]; then
    printf '%s\n' "$GCP_BIND_ADDRESS"
    return 0
  fi

  local iface
  iface="$(route_field "$GCP_HOST" interface)"
  [[ -n "$iface" && "$iface" != utun* ]] || return 0
  ifconfig "$iface" 2>/dev/null | awk '$1 == "inet" { print $2; exit }'
}

health_probe() {
  local ip
  for _ in $(seq 1 "$SOCKS_HEALTH_PROBE_ATTEMPTS"); do
    ip="$(
      ALL_PROXY="socks5h://${LOCAL_SOCKS_HOST}:${LOCAL_SOCKS_PORT}" \
        curl -sS --connect-timeout 5 --max-time "$IP_CHECK_TIMEOUT" "$IP_CHECK_URL" 2>/dev/null || true
    )"
    if [[ "$ip" == "$GCP_EXPECTED_IP" ]]; then
      printf '%s\n' "$ip"
      return 0
    fi
    sleep "$SOCKS_HEALTH_PROBE_DELAY_SECONDS"
  done
  printf '%s\n' "$ip"
}

stop_child() {
  if [[ -n "${ssh_pid:-}" ]] && kill -0 "$ssh_pid" 2>/dev/null; then
    kill "$ssh_pid" 2>/dev/null || true
    sleep 1
    kill -9 "$ssh_pid" 2>/dev/null || true
  fi
}

bind="$(bind_address)"
extra=()
if [[ -n "$GCP_SSH_KEX_ALGORITHMS" ]]; then
  extra+=(-o "KexAlgorithms=$GCP_SSH_KEX_ALGORITHMS")
fi
if [[ -n "$GCP_SSH_HOST_KEY_ALGORITHMS" ]]; then
  extra+=(-o "HostKeyAlgorithms=$GCP_SSH_HOST_KEY_ALGORITHMS")
fi
if [[ -n "$GCP_SSH_CIPHERS" ]]; then
  extra+=(-o "Ciphers=$GCP_SSH_CIPHERS")
fi
if [[ -n "$bind" ]]; then
  extra+=(-b "$bind")
fi

/usr/bin/ssh \
  -N \
  -E "$STATE_DIR/gcp-socks.launchd.ssh.log" \
  -i "$GCP_KEY" \
  -o IdentitiesOnly=yes \
  -o ServerAliveInterval=30 \
  -o ServerAliveCountMax=3 \
  -o ConnectTimeout=20 \
  -o ConnectionAttempts=1 \
  -o ExitOnForwardFailure=yes \
  -o StrictHostKeyChecking=accept-new \
  "${extra[@]}" \
  -D "${LOCAL_SOCKS_HOST}:${LOCAL_SOCKS_PORT}" \
  -p "$GCP_PORT" \
  "${GCP_USER}@${GCP_HOST}" &
ssh_pid=$!
printf '%s\n' "$ssh_pid" > "$STATE_DIR/gcp-socks.manual.pid"
trap stop_child EXIT INT TERM

sleep 3
failures=0
while kill -0 "$ssh_pid" 2>/dev/null; do
  ip="$(health_probe)"
  if [[ "$ip" == "$GCP_EXPECTED_IP" ]]; then
    failures=0
  else
    failures=$((failures + 1))
    printf '[%s] local SOCKS health failed %s/%s: ip=%s expected=%s\n' \
      "$(date '+%Y-%m-%d %H:%M:%S')" \
      "$failures" \
      "$SOCKS_HEALTH_FAILURE_THRESHOLD" \
      "${ip:-empty}" \
      "$GCP_EXPECTED_IP" >> "$STATE_DIR/gcp-socks.health.log"
    if [[ "$failures" -ge "$SOCKS_HEALTH_FAILURE_THRESHOLD" ]]; then
      printf '[%s] exiting to let launchd restart stale local SOCKS tunnel\n' \
        "$(date '+%Y-%m-%d %H:%M:%S')" >> "$STATE_DIR/gcp-socks.health.log"
      stop_child
      exit 1
    fi
  fi
  sleep "$SOCKS_HEALTH_INTERVAL_SECONDS"
done

wait "$ssh_pid"
