#!/usr/bin/env bash
set -euo pipefail

EXPECTED_GCP_HOST="${EXPECTED_GCP_HOST:-203.0.113.10}"
GCP_HOST="${1:-$EXPECTED_GCP_HOST}"
if [[ "$GCP_HOST" != "$EXPECTED_GCP_HOST" ]]; then
  echo "refusing to modify route for unexpected host: $GCP_HOST" >&2
  exit 2
fi

GW="$(/sbin/route -n get default | /usr/bin/awk '/gateway:/{print $2; exit}')"
if [[ -z "$GW" || "$GW" == link#* ]]; then
  echo "no usable default gateway found" >&2
  exit 1
fi

/sbin/route -n change -host "$GCP_HOST" "$GW" 2>/dev/null ||
  /sbin/route -n add -host "$GCP_HOST" "$GW"

/sbin/route -n get "$GCP_HOST"
