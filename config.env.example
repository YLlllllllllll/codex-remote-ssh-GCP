# Copy to ~/.config/codex-gcp-refresh/config.env and edit locally.
# Do not commit the real file.

# Kerberos / organization SSH
PRINCIPAL="user.name@EXAMPLE.REALM"
JUMP_PROXY_SERVICE="host/jump-proxy.example.invalid@EXAMPLE.REALM"
SSH_PROBE_TARGET="remote-workspace.example.invalid"
REMOTE_HOST="$SSH_PROBE_TARGET"
REMOTE_HOME="/home/remote-user"
KINIT_LIFETIME="24h"
KINIT_RENEWABLE_LIFE="7d"

# GCP egress VM
GCP_HOST="192.0.2.10"
GCP_EXPECTED_IP="192.0.2.10"
GCP_USER="gcp-user"
GCP_PORT="443"
GCP_KEY="$HOME/.ssh/google_compute_engine"
SSH_CONNECT_TIMEOUT="20"
GCP_SSH_KEX_ALGORITHMS="curve25519-sha256"
GCP_SSH_HOST_KEY_ALGORITHMS="ssh-ed25519"
GCP_SSH_CIPHERS="chacha20-poly1305@openssh.com"

# Fixed local/remote ports
LOCAL_SOCKS_HOST="127.0.0.1"
LOCAL_SOCKS_PORT="1080"
LOCAL_HTTP_HOST="127.0.0.1"
LOCAL_HTTP_PORT="7890"
REMOTE_HTTP_HOST="127.0.0.1"
REMOTE_HTTP_PORT="10800"

# Probe behavior
IP_CHECK_TIMEOUT="15"
REMOTE_FORWARD_VERIFY_ATTEMPTS="8"
REMOTE_FORWARD_VERIFY_DELAY="2"
VERIFY_FAST_ATTEMPTS="6"
VERIFY_FAST_DELAY="2"
STALE_CODEX_EXEC_MIN_AGE="1800"
GCP_TRAFFIC_IFACE="ens4"
GCP_TRAFFIC_SAMPLE_SECONDS="20"
GCP_TRAFFIC_LIMIT_BYTES="10485760"
CODEX_TCP_SETTLE_SECONDS="12"
CODEX_TCP_MSL="1000"
CODEX_TCP_PORT_RANGE_FIRST="10000"
CODEX_TCP_PORT_RANGE_LAST="65535"
CODEX_REPAIR_LOCK_WAIT_SECONDS="180"
TRAFFIC_24H_WARN_BYTES="1073741824"
TRAFFIC_24H_CRITICAL_BYTES="3221225472"
CODEX_GCP_STABILITY_DURATION_SECONDS="600"
CODEX_GCP_STABILITY_INTERVAL_SECONDS="60"
CODEX_GCP_MAX_LOCAL_TIME_WAIT="10000"
CODEX_GCP_MAX_PROXY_TIME_WAIT="5000"

# Auto-heal reads monitor samples and only repairs when GCP was already enabled.
CODEX_GCP_AUTOHEAL_ENABLED="1"
AUTOHEAL_MIN_CONSECUTIVE_FAILS="2"
AUTOHEAL_COOLDOWN_SECONDS="900"
AUTOHEAL_SOCKET_STORM_COOLDOWN_SECONDS="120"
AUTOHEAL_MAX_SAMPLE_AGE_SECONDS="300"
AUTOHEAL_REPAIR_MODE="remote-gcp"
AUTOHEAL_STALE_SOCKET_THRESHOLD="20"
AUTOHEAL_ALLOW_APP_SERVER_RESTART="0"
SOCKS_HEALTH_INTERVAL_SECONDS="30"
SOCKS_HEALTH_FAILURE_THRESHOLD="6"
SOCKS_HEALTH_PROBE_ATTEMPTS="3"
SOCKS_HEALTH_PROBE_DELAY_SECONDS="2"

# Independent Cursor Remote SSH reset. This is not part of Codex GCP repair.
CURSOR_REMOTE_RESET_MIN_AGE="0"
CURSOR_REMOTE_RESET_KILL_GRACE_SECONDS="3"

# Keychain item used by kinit-refresh save-password
KINIT_KEYCHAIN_SERVICE="example-kinit-refresh"
